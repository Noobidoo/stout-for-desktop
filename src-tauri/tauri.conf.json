{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "stoat-desktop",
  "version": "1.3.0",
  "identifier": "chat.stoat.stoat-desktop",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "frontendDist": "https://stoat.chat/app",
    "devUrl": "https://stoat.chat/app"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Stoat",
        "url": "https://stoat.chat/app",
        "minWidth": 300,
        "minHeight": 300,
        "width": 1280,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
